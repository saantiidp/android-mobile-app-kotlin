<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="event"
            type="com.example.expomanager.Event" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardElevation="6dp"
        app:cardCornerRadius="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#61A0D9">

            <ImageView
                android:id="@+id/imageViewEvent"
                android:layout_width="216dp"
                android:layout_height="157dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="20dp"
                android:layout_centerHorizontal="true"
                android:layout_marginEnd="161dp"
                android:layout_below="@id/textViewEventName"
                android:scaleType="centerCrop"
                android:visibility="visible"
                tools:src="@drawable/ic_launcher_background" />

            <TextView
                android:id="@+id/textViewEventName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginStart="35dp"
                android:layout_marginTop="12dp"
                android:text="@{event.name}"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/textViewEventShortDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textViewEventName"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="140dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="5dp"
                android:paddingStart="120dp"
                android:text="@{event.descriptionShort}"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E0D9D9"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEvent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/button_see_details"
                android:textSize="12sp"
                android:layout_below="@id/textViewEventShortDesc"
                android:layout_alignParentEnd="true"
                app:cornerRadius="8dp" />
        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>
</layout>
